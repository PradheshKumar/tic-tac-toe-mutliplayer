# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Nakama server key (must match --name in docker-compose / server config)
VITE_NAKAMA_KEY=defaultkey

# Nakama server host — use 127.0.0.1 locally, your Railway/Fly.io URL in production
VITE_NAKAMA_HOST=127.0.0.1

# Nakama HTTP/WebSocket port — 7350 locally, 443 in production (behind TLS)
VITE_NAKAMA_PORT=7350

# Set to "true" when deploying behind HTTPS (Railway, Fly.io, etc.)
VITE_NAKAMA_SSL=false
